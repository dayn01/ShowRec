# Loaded only by `npm run build:capacitor` (vite build --mode capacitor),
# i.e. the build packaged into the Android APK for the NVIDIA Shield.
# Points the app at the backend over the LAN. Change if the server IP/port
# changes. The plain `npm run build` (used by the Docker web image) does NOT
# load this file, so the web app served at :8087 stays on relative /api paths.
VITE_API_URL=http://192.168.0.116:8087
