# Copy this to .env and fill in your values.

# --- Timezone (optional) ---
# IANA name for the daily notification schedule (episode/new-season checks at
# 08:00/09:00). Defaults to UTC — set your local zone or the checks fire in UTC.
#TIMEZONE=Australia/Sydney

# --- TMDB (required) ---
TMDB_API_KEY=

# --- Trakt (optional) ---
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=

# --- Jellyfin (optional) ---
# Must be reachable from inside Docker — use a public domain or LAN IP, NOT localhost.
JELLYFIN_URL=
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=
# Optional but recommended: your Jellyfin username. The user id above can change if
# Jellyfin is reinstalled/migrated; with the username set, the app re-resolves and
# repairs the id automatically instead of silently breaking sync.
JELLYFIN_USERNAME=

# --- Plex (optional) ---
#PLEX_URL=http://192.168.1.x:32400
#PLEX_TOKEN=

# --- Overseerr / Jellyseerr (optional) ---
# Adds a "Request" button + availability badges that auto-request via Sonarr/Radarr.
# Works with EITHER Overseerr or Jellyseerr (identical API) — the var names stay
# OVERSEERR_* regardless. For TV, only your unwatched seasons are requested.
# Must be reachable from inside Docker — use a LAN IP or domain, NOT localhost.
# API key: Overseerr/Jellyseerr → Settings → General → API Key.
#OVERSEERR_URL=http://192.168.1.x:5055
#OVERSEERR_API_KEY=

# --- Anthropic / Claude (optional, powers AI picks) ---
ANTHROPIC_API_KEY=

# --- Reddit (optional, adds buzz to AI picks) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- TasteDive (optional, "More Like This" similar titles in details) ---
# Free key: https://tastedive.com/account/api_access
TASTEDIVE_API_KEY=

# --- Home Assistant (optional, episode notifications) ---
# Use the LAN IP, NOT homeassistant.local (mDNS doesn't resolve inside Docker).
HA_URL=http://192.168.1.x:8123
HA_TOKEN=
HA_NOTIFICATION_SERVICE=notify.notify
